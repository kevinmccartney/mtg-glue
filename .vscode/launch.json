{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach debugpy (port 5678)",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}/projects",
          "remoteRoot": "${workspaceFolder}/projects"
        }
      ],
      "justMyCode": true
    }
  ]
}
