# Terraform
NOTIFICATION_SENDER_EMAIL=test@example.com
NOTIFICATION_RECIPIENT_EMAIL=test@example.com
AWS_REGION=us-east-1
TF_STATE_BUCKET=test-state-bucket

# Logging: console (default) or json (one JSON line per event; use for ECS/CloudWatch).
LOG_FORMAT=console
LOG_LEVEL=INFO

# ETL (EchoMTG → Moxfield)
ECHOMTG_USERNAME=test@example.com
ECHOMTG_PASSWORD=password
MOXFIELD_USERNAME=test@example.com
MOXFIELD_PASSWORD=password
# CapSolver: injected into extension assets/config.js at runtime (Docker)
CAPSOLVER_API_KEY=
# Optional. Docker: /opt/capsolver-extension. Local: run_headed_local.sh uses .data/capsolver-extension (auto-downloaded).
# CAPSOLVER_EXTENSION_PATH=
# Optional: show EchoMTG export in a visible browser (default headless).
# ECHO_MTG_HEADED=1
S3_BUCKET=test-bucket
# ETL only: keep this many newest timestamped CSVs per family under echomtg/ and moxfield/ (default 20). 0 = disable.
S3_CSV_RETENTION_COUNT=20
# ETL only: Moxfield UI step screenshots → .data/ and s3://$S3_BUCKET/etl/screenshots/<run_timestamp>/
# ETL_DEBUG_SCREENSHOTS=1
# ETL only: load config from S3 when set (with S3_BUCKET). CLI always uses --config (default ./config.yaml).
MTG_GLUE_CONFIG_S3_KEY=config/config.yaml
